---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const blogEntries = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Blog | Kyrux">
  <section>
    <h1 class="text-3xl font-semibold text-zinc-100">Technical Blog</h1>
    <p class="mt-3 text-zinc-400">
      Research notes on web security, tooling, reverse engineering, and exploitation workflows.
    </p>
  </section>

  <ul class="mt-8 space-y-4">
    {
      blogEntries.map((entry) => (
        <li class="rounded-lg border border-zinc-800 bg-zinc-900/40 p-4">
          <a href={`/blog/${entry.id}/`} class="text-xl font-medium text-zinc-100 hover:text-emerald-300">
            {entry.data.title}
          </a>
          <p class="mt-2 text-sm text-zinc-400">{entry.data.description}</p>
          <p class="mt-2 text-xs text-zinc-500">{entry.data.tags.map((tag) => `#${tag}`).join(" ")}</p>
        </li>
      ))
    }
  </ul>
</BaseLayout>
