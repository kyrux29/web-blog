---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
const withBase = (path: string) =>
  `${import.meta.env.BASE_URL.replace(/\/?$/, "/")}${path.replace(/^\//, "")}`;

const blogEntries = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Blog | Kyrux">
  <section class="mb-6">
    <h1 class="text-4xl font-semibold tracking-tight text-slate-100">Research Archive</h1>
    <p class="mt-3 max-w-3xl text-slate-400">
      Research notes on web security, tooling, reverse engineering, and exploitation workflows.
    </p>
    <div class="mt-5">
      <input
        id="blog-search"
        type="search"
        placeholder="Search by title, tags, or summary..."
        class="w-full rounded-xl border border-slate-700 bg-slate-900/70 px-4 py-2 text-sm text-slate-100 placeholder:text-slate-500 focus:border-cyan-500 focus:outline-none"
      />
    </div>
  </section>

  <ul id="blog-list" class="mt-8 space-y-4">
    {
      blogEntries.map((entry) => (
        <li
          class="panel group p-5 transition hover:border-cyan-700/70 hover:bg-slate-900/80"
          data-search={`${entry.data.title} ${entry.data.description} ${entry.data.tags.join(" ")}`.toLowerCase()}
        >
          <div class="mb-3 flex flex-wrap items-center gap-2 text-xs">
            <span class="chip">{entry.data.date.toLocaleDateString("en-CA")}</span>
            <span class="chip">Research</span>
          </div>
          <a
            href={withBase(`/blog/${entry.id}/`)}
            class="text-2xl font-medium leading-tight text-slate-100 hover:text-cyan-300"
          >
            {entry.data.title}
          </a>
          <p class="mt-3 text-sm text-slate-400">{entry.data.description}</p>
          <div class="mt-4 flex items-center justify-between gap-3">
            <div class="flex flex-wrap gap-2">
              {entry.data.tags.map((tag) => <span class="chip">{tag}</span>)}
            </div>
            <span class="text-lg text-slate-500 transition group-hover:text-cyan-300" aria-hidden="true">→</span>
          </div>
        </li>
      ))
    }
  </ul>

  <p id="blog-empty" class="mt-6 hidden text-sm text-slate-400">No matching posts found.</p>

  <script is:inline>
    const blogSearch = document.getElementById("blog-search");
    const blogItems = Array.from(document.querySelectorAll("#blog-list > li"));
    const blogEmpty = document.getElementById("blog-empty");

    const runBlogFilter = () => {
      const query = (blogSearch?.value ?? "").trim().toLowerCase();
      let visible = 0;
      blogItems.forEach((item) => {
        const haystack = item.getAttribute("data-search") ?? "";
        const match = !query || haystack.includes(query);
        item.classList.toggle("hidden", !match);
        if (match) visible += 1;
      });
      blogEmpty?.classList.toggle("hidden", visible > 0);
    };

    blogSearch?.addEventListener("input", runBlogFilter);
  </script>
</BaseLayout>
