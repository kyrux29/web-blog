---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;

const ctfEntries = (await getCollection("ctf", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="CTF Write-ups | Kyrux">
  <section>
    <h1 class="text-3xl font-semibold text-slate-100">CTF Write-ups</h1>
    <p class="mt-3 text-slate-400">Hands-on challenge solutions, exploit notes, and methodology breakdowns.</p>
  </section>

  <ul class="mt-8 space-y-4">
    {
      ctfEntries.map((entry) => (
        <li class="rounded-lg border border-slate-800 bg-slate-900/40 p-4">
          <a href={withBase(`/ctf/${entry.id}/`)} class="text-xl font-medium text-slate-100 hover:text-cyan-300">
            {entry.data.title}
          </a>
          <p class="mt-2 text-sm text-slate-400">
            {entry.data.platform} - {entry.data.vulnerability_type}
          </p>
          <p class="mt-2 text-xs text-slate-500">
            {entry.data.tags.map((tag) => `#${tag}`).join(" ")}
          </p>
        </li>
      ))
    }
  </ul>
</BaseLayout>
