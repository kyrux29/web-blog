---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Kyrux cybersecurity research blog" } = Astro.props;
const withBase = (path: string) =>
  `${import.meta.env.BASE_URL.replace(/\/?$/, "/")}${path.replace(/^\//, "")}`;

const navLinks = [
  { href: withBase("/"), label: "Home" },
  { href: withBase("/ctf/"), label: "CTF" },
  { href: withBase("/blog/"), label: "Blog" },
  { href: "https://github.com/kyrux29", label: "GitHub", external: true }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="icon" href={withBase("/favicon.ico")} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <div class="mx-auto flex min-h-screen w-full max-w-5xl flex-col px-4 py-6 sm:px-6 lg:px-8">
      <header class="mb-10">
        <div class="panel mx-auto flex max-w-4xl items-center justify-between gap-3 px-3 py-2">
          <a
            href={withBase("/")}
            class="rounded-full border border-slate-700 bg-slate-950 px-4 py-1.5 text-sm font-semibold tracking-wider text-slate-100"
          >
            KYRUX_LABS
          </a>
          <nav aria-label="Main Navigation">
            <ul class="flex items-center gap-3 text-xs sm:gap-5 sm:text-sm">
              {
                navLinks.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      target={link.external ? "_blank" : undefined}
                      rel={link.external ? "noreferrer" : undefined}
                      class="text-slate-400 hover:text-cyan-300"
                    >
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
          <a
            href={withBase("/blog/")}
            class="rounded-full bg-cyan-400 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-slate-950 hover:bg-cyan-300"
          >
            Explore
          </a>
        </div>
      </header>

      <main class="flex-1">
        <slot />
      </main>

      <footer class="mt-14 border-t border-slate-800 pt-6 text-sm text-slate-500">
        <p>© {new Date().getFullYear()} Kyrux | Vu Trong Quoc Khanh.</p>
      </footer>
    </div>
  </body>
</html>
