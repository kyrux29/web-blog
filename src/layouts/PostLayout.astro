---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, date, description, tags = [], headings = [] } = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<BaseLayout title={`${title} | Kyrux`} description={description}>
  <article class="mx-auto max-w-7xl lg:grid lg:grid-cols-[minmax(0,1fr)_280px] lg:gap-10">
    <div class="min-w-0">
      <header class="panel mb-8 p-6">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span class="chip">Research</span>
          {
            tags.map((tag) => <span class="chip">{tag}</span>)
          }
        </div>
        <div class="mb-3 flex flex-wrap items-center gap-2">
        <span class="chip">
          <time datetime={date.toISOString()}>{date.toLocaleDateString("en-CA")}</time>
        </span>
        </div>
        <h1 class="text-3xl font-semibold leading-tight text-slate-100 md:text-5xl">{title}</h1>
        <p class="mt-3 text-sm text-slate-400">
          <time datetime={date.toISOString()}>{date.toLocaleDateString("en-US", { dateStyle: "long" })}</time>
        </p>
      </header>

      {tocHeadings.length > 0 && (
        <details class="panel mb-6 p-4 lg:hidden">
          <summary class="cursor-pointer text-xs font-semibold uppercase tracking-wider text-slate-300">
            Quick Nav
          </summary>
          <ul class="mt-3 space-y-2 text-sm">
            {tocHeadings.map((heading) => (
              <li class={heading.depth === 3 ? "ml-3" : ""}>
                <a href={`#${heading.slug}`} class="toc-link text-slate-400 hover:text-cyan-300">
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </details>
      )}

      <div class="mx-auto max-w-3xl">
        <div
          class="prose prose-invert prose-slate max-w-none prose-headings:mt-10 prose-headings:tracking-tight prose-h2:text-3xl prose-p:leading-8 prose-pre:rounded-2xl prose-pre:border prose-pre:border-slate-700 prose-pre:bg-slate-900 prose-pre:p-5 prose-pre:text-slate-100 prose-pre:shadow-lg prose-code:before:content-none prose-code:after:content-none prose-blockquote:rounded-xl prose-blockquote:border-l-4 prose-blockquote:border-cyan-500 prose-blockquote:bg-slate-900/80 prose-blockquote:px-4 prose-blockquote:py-3 prose-blockquote:text-slate-300"
        >
        <slot />
        </div>
      </div>
    </div>

    {tocHeadings.length > 0 && (
      <aside class="hidden lg:block">
        <div class="panel sticky top-6 p-4">
          <h2 class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Quick Nav</h2>
          <ul class="space-y-2 text-sm">
            {tocHeadings.map((heading) => (
              <li class={heading.depth === 3 ? "ml-3" : ""}>
                <a href={`#${heading.slug}`} data-toc-link={heading.slug} class="toc-link text-slate-400 hover:text-cyan-300">
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    )}
  </article>

  <script is:inline>
    const links = Array.from(document.querySelectorAll("[data-toc-link]"));
    const sections = links
      .map((link) => document.getElementById(link.getAttribute("data-toc-link")))
      .filter(Boolean);

    if (links.length > 0 && sections.length > 0) {
      const activate = (id) => {
        links.forEach((link) => {
          const active = link.getAttribute("data-toc-link") === id;
          link.classList.toggle("toc-active", active);
          link.classList.toggle("text-cyan-300", active);
          link.classList.toggle("font-medium", active);
          link.classList.toggle("text-slate-400", !active);
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
          if (visible?.target?.id) activate(visible.target.id);
        },
        { rootMargin: "-20% 0px -70% 0px", threshold: 0.1 }
      );

      sections.forEach((section) => observer.observe(section));
      activate(sections[0].id);
    }
  </script>
</BaseLayout>
