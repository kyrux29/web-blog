---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  date: Date;
  description?: string;
}

const { title, date, description } = Astro.props;
---

<BaseLayout title={`${title} | Kyrux`} description={description}>
  <article class="mx-auto max-w-3xl">
    <header class="panel mb-8 p-6">
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <span class="chip">Research</span>
        <span class="chip">
          <time datetime={date.toISOString()}>{date.toLocaleDateString("en-CA")}</time>
        </span>
      </div>
      <h1 class="text-3xl font-semibold leading-tight text-slate-100 md:text-5xl">{title}</h1>
      <p class="mt-3 text-sm text-slate-400">
        <time datetime={date.toISOString()}>{date.toLocaleDateString("en-US", { dateStyle: "long" })}</time>
      </p>
    </header>

    <div
      class="prose prose-invert prose-slate max-w-none prose-headings:mt-10 prose-headings:tracking-tight prose-h2:text-3xl prose-p:leading-8 prose-pre:rounded-2xl prose-pre:border prose-pre:border-slate-700 prose-pre:bg-slate-900 prose-pre:p-5 prose-pre:text-slate-100 prose-pre:shadow-lg prose-code:rounded prose-code:bg-slate-900 prose-code:px-1 prose-code:py-0.5 prose-code:text-cyan-300 prose-code:before:content-none prose-code:after:content-none prose-blockquote:rounded-xl prose-blockquote:border-l-4 prose-blockquote:border-cyan-500 prose-blockquote:bg-slate-900/80 prose-blockquote:px-4 prose-blockquote:py-3 prose-blockquote:text-slate-300"
    >
      <slot />
    </div>
  </article>
</BaseLayout>
